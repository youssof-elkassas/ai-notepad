# ─────────────────────────────────────────────────────────────
#  AI Notepad — Environment Configuration
# ─────────────────────────────────────────────────────────────

# PRIMARY (free): Get your key at https://aistudio.google.com
# No credit card required. 1,500 requests/day free tier.
GOOGLE_API_KEY=your_google_api_key_here

# OPTIONAL FALLBACK: OpenAI (paid, ~$0.01 per run)
# Only used if LLM_PROVIDER=openai
OPENAI_API_KEY=

# VLM provider to use: "gemini" (default, free) or "openai" (paid)
LLM_PROVIDER=gemini

# Gemini model to use (default is free-tier capable)
GEMINI_MODEL=gemini-2.5-flash

# OpenAI model (only used when LLM_PROVIDER=openai)
OPENAI_MODEL=gpt-4o

# Grounding retry attempts before giving up
MAX_GROUNDING_RETRIES=3

# Plain-English target for VLM grounding (default: Notepad desktop shortcut icon)
GROUNDING_QUERY=Notepad desktop shortcut icon

# Visual hints for the VLM (optional; omit to use built-in Notepad description)
# Use \n for line breaks, e.g.:
# GROUNDING_VISUAL_DESCRIPTION=- A small desktop shortcut icon\n- Blue document with lines\n- Label reads "Notepad"

# Check for and dismiss blocking dialogs before grounding (true/false, default: true)
CHECK_POPUPS=true

# Save copies of images sent to the VLM under screenshots/vlm_trace/ (true/false, default: true)
VLM_TRACE=true

# Seconds to wait after launching Notepad before interacting
NOTEPAD_LAUNCH_WAIT=2.0

# Pixels added to grounded Y before double-clicking (icon label offset)
NOTEPAD_CLICK_OFFSET_Y=20
